<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Books</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <main class="container">
        <div class="top-bar">
            <h1>All Books</h1>
            <a href="/books/new" class="btn add-btn">Add New Book</a>
        </div>

        <section class="book-list">
            <% for (let book of books) { %>
                <article class="book-card">
                    <div class="book-header">
                        <h2 class="title-text"><%= book.book_name %></h2>
                        <span class="price">$<%= book.price %></span>
                    </div>

                    <p class="author"><strong>Author:</strong> <%= book.author_name %></p>
                    <p class="genre"><strong>Genre:</strong> <%= book.genre %></p>
                    <p class="description"><%= book.description.split(' ').slice(0, 10).join(' ') %><% if (book.description.split(' ').length > 10) { %>...<% } %></p>

                    <div class="book-actions">
                        <a href="/books/view/<%= book._id %>" class="btn view-btn">View</a>
                        <a href="/books/<%= book._id %>/edit" class="btn edit-btn">Edit</a>
                        <form action="/books/<%= book._id %>?_method=DELETE" method="POST" class="delete-form">
                            <button type="submit" class="btn delete-btn">Delete</button>
                        </form>
                    </div>
                </article>
            <% } %>
        </section>
    </main>
</body>
</html>